[Unit]
Description=Cloudflare Quick Tunnel for BSUIR Nexus
After=network.target nginx.service bsuir-backend.service

[Service]
Type=simple
User=admin
ExecStart=/bin/bash /opt/bsuir-nexus/server/start-tunnel.sh
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
